<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal">

        <Button
            android:id="@+id/btnWifi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/wifi_settings"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnBluetooth"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/bluetooth_settings"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnDisplay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/display_settings"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnSound"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sound_settings"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnBattery"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/battery_settings"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnApps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/apps_permissions"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnAccessibility"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/accessibility"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnAbout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/about_phone"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnAirplane"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/toggle_airplane_mode"
            android:enabled="false"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnRootLogin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/root_login" />

    </LinearLayout>
</ScrollView>
