diff --git a/kernel/fs/vfs.c b/kernel/fs/vfs.c
index 0000000..0000000 100644
--- a/kernel/fs/vfs.c
+++ b/kernel/fs/vfs.c
@@
+// Normalize path (remove trailing slash except root)
+static void normalize_path(char *path) {
+    size_t len = strlen(path);
+    while (len > 1 && path[len - 1] == '/') {
+        path[len - 1] = '\0';
+        len--;
+    }
+}

 int vfs_mount(const char *target, struct fs *fs) {
+    char norm_target[256];
+    strncpy(norm_target, target, sizeof(norm_target));
+    normalize_path(norm_target);

     for (int i = 0; i < MAX_MOUNTS; i++) {
-        if (strcmp(mounts[i].target, target) == 0) {
+        char existing[256];
+        strncpy(existing, mounts[i].target, sizeof(existing));
+        normalize_path(existing);
+
+        if (strcmp(existing, norm_target) == 0) {
             return -EEXIST;
         }
     }

     for (int i = 0; i < MAX_MOUNTS; i++) {
         if (!mounts[i].used) {
             mounts[i].used = 1;
             mounts[i].fs = fs;
-            strncpy(mounts[i].target, target, sizeof(mounts[i].target));
+            strncpy(mounts[i].target, norm_target, sizeof(mounts[i].target));
             return 0;
         }
     }
     return -ENOMEM;
 }

