diff --git a/boot/bios/stage1.S b/boot/bios/stage1.S
index 0000000..0000000 100644
--- a/boot/bios/stage1.S
+++ b/boot/bios/stage1.S
@@
     cli
     xor ax, ax
     mov ds, ax

+    ; Detect INT13 extensions (LBA support)
+    mov ah, 0x41
+    mov bx, 0x55AA
+    int 0x13
+    jc no_lba
+    cmp bx, 0xAA55
+    jne no_lba
+
+    mov byte [use_lba], 1
+    jmp load_stage2
+
+no_lba:
+    mov byte [use_lba], 0

 load_stage2:

diff --git a/scripts/build_dos_image.sh b/scripts/build_dos_image.sh
index 0000000..0000000 100755
--- a/scripts/build_dos_image.sh
+++ b/scripts/build_dos_image.sh
@@
+# Calculate stage2 sector count
+STAGE2_SIZE=$(stat -c%s stage2.bin)
+SECTORS=$(( (STAGE2_SIZE + 511) / 512 ))
+
+# Patch sector count into stage1 (offset 2)
+printf "\\x%02x\\x%02x" $((SECTORS & 0xff)) $(((SECTORS >> 8) & 0xff)) \
+  | dd of=stage1.bin bs=1 seek=2 conv=notrunc
+
+# Pad stage2 to full sectors
+dd if=/dev/zero bs=512 count=$SECTORS | cat stage2.bin - \
+  | dd of=stage2_padded.bin bs=512 count=$SECTORS
+
+# Write padded stage2
+dd if=stage2_padded.bin of=disk.img bs=512 seek=1 conv=notrunc
